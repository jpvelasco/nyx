#!/usr/bin/env node

const { spawn } = require('child_process');
const path = require('path');
const os = require('os');
const fs = require('fs/promises');

function getBinaryName() {
  const platform = os.platform();
  const arch = os.arch();

  const platformMap = {
    linux: 'linux',
    darwin: 'darwin',
    win32: 'windows',
  };

  const archMap = {
    x64: 'amd64',
    arm64: 'arm64',
  };

  const p = platformMap[platform];
  const a = archMap[arch];

  if (!p || !a) {
    throw new Error(`Unsupported platform: ${platform}-${arch}`);
  }

  const ext = platform === 'win32' ? '.exe' : '';
  return `nyx-${p}-${a}${ext}`;
}

function exitCodeForSignal(signal) {
  const signalNumber = signal ? os.constants.signals[signal] : 0;
  return signalNumber ? 128 + signalNumber : 1;
}

async function main() {
  const binaryName = getBinaryName();
  const binaryPath = path.join(__dirname, binaryName);  // nosemgrep: generic.dynamic-path-construction

  try {
    await fs.access(binaryPath);
  } catch (err) {
    console.error(`Binary not found: ${binaryPath}`);
    console.error('Reinstall @nyx/cli so npm can download the platform binary.');
    process.exit(1);
  }

  const child = spawn(binaryPath, process.argv.slice(2), {  // nosemgrep: generic.os-command-injection
    stdio: 'inherit',
    windowsHide: true,
  });

  child.on('error', (err) => {
    console.error(`Failed to start nyx binary: ${err.message}`);
    process.exit(1);
  });

  child.on('exit', (code, signal) => {
    if (code !== null) {
      process.exit(code);
    }

    console.error(`nyx terminated by ${signal || 'an unknown signal'}`);
    process.exit(exitCodeForSignal(signal));
  });
}

main().catch((err) => {
  console.error(err.message);
  process.exit(1);
});
